DENdb=DENdb %>% filter(trait_name=="Skeletal density") %>% mutate(sden=as.numeric(value))
DENdb %>% ggplot(aes(x=specie_name,y=sden))+geom_boxplot()
DENdb %>% ggplot(aes(x=specie_name,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))
DENdb=DENdb %>% filter(trait_name=="Skeletal density") %>% mutate(sden=as.numeric(value),genus=substr(specie_name,1,grep(" ",specie_name)))
DENdb
grep(" ",specie_name)
grep(" ",DENdb$specie_name)
grep(pattern = " ",x=DENdb$specie_name)
sub(pattern = " ",x=DENdb$specie_name)
regexpr(pattern = " ",x=DENdb$specie_name)
regexpr(pattern = " ",text = DENdb$specie_name)
DENdb=DENdb %>% filter(trait_name=="Skeletal density") %>%
mutate(sden=as.numeric(value),genus=substr(specie_name,1,regexpr(pattern = " ",text = specie_name)))
DENdb
DENdb %>% ggplot(aes(x=specie_name,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))+facet_wrap("genus")
DENdb %>% ggplot(aes(x=specie_name,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))+facet_wrap("genus",drop=T)
DENdb %>% ggplot(aes(x=specie_name,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))+facet_wrap("genus",scales="free_x",drop=T)
DENdb %>% ggplot(aes(x=genus,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))
genmed=DENdb %>% group_by(genus) %>% reframe(sden_med=median(sden))
genmed
genmed
genmed=DENdb %>% group_by(genus) %>% reframe(sden_med=median(sden)) %>% arrange(sden_med)
genmed
genmed=DENdb %>% group_by(genus) %>% reframe(sden_med=median(sden)) %>% arrange(desc(sden_med))
genmed
mutate(genus=factor(genus,levels = genmed$genus)
)
DENdb=DENdb %>%
mutate(genus=factor(genus,levels = genmed$genus))
DENdb %>% ggplot(aes(x=genus,y=sden))+geom_boxplot()+theme(axis.text.x = element_text(angle=90))
