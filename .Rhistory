tr$out[cnt]=tr$delPA[cnt]/vs$P[i]
tr$up[cnt]=(tr$delSA[cnt]-tr$delPA[cnt])/vs$PA[i]
tr$delRug[cnt]=(vs$SA[j]/vs$PA[j])-(vs$SA[i]/vs$PA[i])
hi=(vs$SA[i]-vs$PA[i])/vs$P[i]
hj=(vs$SA[j]-vs$PA[j])/vs$P[j]
tr$delH[cnt]=hj-hi
tr$sap[cnt]=tr$delSA[cnt]/vs$P[i]
tr$volLE[cnt]=tr$delV[cnt]/vs$SA[i]
tr$mn_ou[cnt]=mean(c(tr$out[cnt],tr$up[cnt]))
tr$mx_ou[cnt]=max(c(tr$out[cnt],tr$up[cnt]))
tr$mx_oh[cnt]=max(c(tr$out[cnt],tr$delH[cnt]))
cnt=cnt+1
}
}
